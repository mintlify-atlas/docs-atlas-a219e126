  "keyFeatures": [
    "Real-time scrap registration with barcode scanner support",
    "Interactive dashboards with charts and trend analysis",
    "Role-based access control with granular permissions",
    "Comprehensive reporting by area, shift, chain, and category",
    "Tolerance management with automatic alerts",
    "Complete audit trail and backup/restore functionality",
    "Multi-shift support with configurable schedules",
    "CSV import/export for catalogs and data migration"
  ],
